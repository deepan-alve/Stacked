# ============================================
# Stacked Environment Configuration
# ============================================
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# ----------------------------------------
# App Configuration
# ----------------------------------------
NODE_ENV=production

# ----------------------------------------
# Domain (for SSL certificate)
# ----------------------------------------
# Set your domain for production
DOMAIN=localhost
ACME_EMAIL=your@email.com

# ----------------------------------------
# Supabase Backup (PostgreSQL)
# ----------------------------------------
# Get these from: Supabase Dashboard > Settings > Database > Connection string
SUPABASE_DB_HOST=db.xxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-password

# ----------------------------------------
# Backup Settings
# ----------------------------------------
# How often to sync to Supabase (in hours)
BACKUP_INTERVAL_HOURS=6
