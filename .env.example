# Dokploy Environment Variables
# Add these in Dokploy's environment variables section

# Required
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://localhost:5173

# Optional - for movie/book metadata
TMDB_API_KEY=your_tmdb_api_key
OMDB_API_KEY=your_omdb_api_key

# Optional - backup interval in hours (default: 6)
BACKUP_INTERVAL_HOURS=6

# Optional - Git sync is disabled unless explicitly enabled
ENABLE_GIT_SYNC=false
GITHUB_TOKEN=your_github_token
GITHUB_REPO=your-org/your-repo
SYNC_BRANCH=main
SYNC_ADMIN_EMAILS=you@example.com
